import { defineStore } from 'pinia'
import { ref, computed } from 'vue'
import type { {{name}} } from '@/types/{{lowerName}}'
import {
  get{{name}}List,
  get{{name}}Detail,
  create{{name}},
  update{{name}},
  delete{{name}},
  type {{name}}ListParams
} from '@/api/{{lowerName}}'

export const use{{name}}Store = defineStore('{{lowerName}}', () => {
  // State
  const list = ref<{{name}}[]>([])
  const total = ref(0)
  const loading = ref(false)
  const current{{name}} = ref<{{name}} | null>(null)

  // Getters
  const {{lowerName}}List = computed(() => list.value)
  const {{lowerName}}Total = computed(() => total.value)
  const isLoading = computed(() => loading.value)

  // Actions
  const fetchList = async (params: {{name}}ListParams) => {
    loading.value = true
    try {
      const res = await get{{name}}List(params)
      list.value = res.list
      total.value = res.total
      return res
    } finally {
      loading.value = false
    }
  }

  const fetchDetail = async (id: string) => {
    loading.value = true
    try {
      const res = await get{{name}}Detail(id)
      current{{name}}.value = res
      return res
    } finally {
      loading.value = false
    }
  }

  const create = async (data: Partial<{{name}}>) => {
    const res = await create{{name}}(data)
    return res
  }

  const update = async (id: string, data: Partial<{{name}}>) => {
    const res = await update{{name}}(id, data)
    return res
  }

  const remove = async (id: string) => {
    await delete{{name}}(id)
  }

  return {
    list,
    total,
    loading,
    current{{name}},
    {{lowerName}}List,
    {{lowerName}}Total,
    isLoading,
    fetchList,
    fetchDetail,
    create,
    update,
    remove
  }
})
